{
    "layer": "top",
    "position": "top",
    "height": 28,
    "spacing": 4,
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["clock"],
    "modules-right": ["network", "bluetooth", "wireplumber", "cpu", "memory", "battery", "tray"],

    "sway/workspaces": {
        "disable-scroll": false,
        "format": "{name}"
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "clock": {
        "format": "  {:%a %d %b  %H:%M}",
        "tooltip-format": "<tt><big>{calendar}</big></tt>",
        "format-alt": "  {:%Y-%m-%d %H:%M:%S}"
    },
    "network": {
        "format-wifi": "  {essid} ({signalStrength}%)",
        "format-ethernet": "  {ipaddr}",
        "format-linked": "  {ifname}",
        "format-disconnected": "  off",
        "tooltip-format": "{ifname} via {gwaddr}",
        "on-click": "sway-wifi-menu"
    },
    "bluetooth": {
        "format": "  {status}",
        "format-connected": "  {device_alias}",
        "format-disabled": "",
        "tooltip-format": "{controller_alias}\t{status}",
        "tooltip-format-connected": "{controller_alias}\t{status}\n{device_enumerate}",
        "on-click": "foot --app-id=floatterm -T bluetooth bluetoothctl"
    },
    "wireplumber": {
        "format": "  {volume}%",
        "format-muted": "  muted",
        "on-click": "sway-audio-menu",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-",
        "max-volume": 150
    },
    "cpu": {
        "format": "  {usage}%",
        "interval": 5
    },
    "memory": {
        "format": "  {percentage}%",
        "interval": 5
    },
    "battery": {
        "states": { "warning": 30, "critical": 15 },
        "format": "{icon}  {capacity}%",
        "format-charging": "  {capacity}%",
        "format-plugged": "  {capacity}%",
        "format-icons": ["", "", "", "", ""],
        "tooltip": true
    },
    "tray": {
        "icon-size": 18,
        "spacing": 8
    }
}
