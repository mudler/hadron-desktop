#!/bin/sh
# Per-boot per-user setup, run late (after users exist and /home is mounted) by
# hadron-user-setup.service. Idempotent.
#
#  - the Flathub remote per human user (--user installs land on persistent
#    /home, so the remote persists; --if-not-exists makes re-runs cheap).
#    Added with --no-gpg-verify because the image ships libgpgme but no gpg.
#
# (Docker is rootful and needs no per-user subuid/subgid mapping, so unlike the
# old podman setup this no longer touches /etc/subuid or /etc/subgid.)
for u in $(awk -F: '$3>=1000 && $3<60000 {print $1}' /etc/passwd); do
    home=$(awk -F: -v u="$u" '$1==u {print $6}' /etc/passwd)
    if [ -d "$home" ]; then
        su - "$u" -c 'flatpak --user remote-add --if-not-exists --no-gpg-verify \
            flathub https://dl.flathub.org/repo/' >/dev/null 2>&1 || true
    fi
done
