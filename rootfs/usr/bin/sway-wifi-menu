#!/bin/sh
# fuzzel-based Wi-Fi menu for sway (NetworkManager via nmcli). Bound to Mod+w.
# No tray/applet needed — a dmenu picker over `nmcli`.
menu() { fuzzel --dmenu --width=48 --lines=14 --prompt="$1"; }

radio=$(nmcli -t -f WIFI radio 2>/dev/null || echo "")
if [ "$radio" = "disabled" ]; then
    [ "$(printf 'Turn Wi-Fi on' | menu 'Wi-Fi is off > ')" = "Turn Wi-Fi on" ] && nmcli radio wifi on
    exit 0
fi

nmcli device wifi rescan >/dev/null 2>&1 || true

# One line per SSID (strongest kept): "● SSID  (72% *)"  — ● = connected, * = secured.
aps=$(nmcli -t --escape no -f ACTIVE,SIGNAL,SECURITY,SSID device wifi list 2>/dev/null | awk -F: '
    { ssid=$4; for (i=5; i<=NF; i++) ssid=ssid ":" $i }
    ssid=="" || seen[ssid]++ { next }
    {
        mark = ($1 == "yes") ? "\xe2\x97\x8f " : "  "
        sec  = ($3 == "" || $3 == "--") ? "" : " *"
        printf "%s%s  (%d%%%s)\n", mark, ssid, $2, sec
    }')

sel=$(printf '%s\n  ─────────\n  Disconnect\n  Turn Wi-Fi off\n  Rescan' "$aps" | menu 'Wi-Fi > ') || exit 0

# strip leading marker and the "  (NN% ...)" suffix to recover the SSID / action
clean=$(printf '%s' "$sel" | sed -e 's/^[● ] *//' -e 's/  *$//')
case "$clean" in
    ''|'─────────') exit 0 ;;
    'Turn Wi-Fi off') nmcli radio wifi off; exit 0 ;;
    'Rescan') exec "$0" ;;
    'Disconnect')
        dev=$(nmcli -t -f DEVICE,TYPE device | awk -F: '$2=="wifi"{print $1; exit}')
        [ -n "$dev" ] && nmcli device disconnect "$dev"
        exit 0 ;;
esac

ssid=$(printf '%s' "$clean" | sed -E 's/  *\([0-9]+%.*\)$//')
[ -n "$ssid" ] || exit 0

if nmcli -t -f NAME connection show 2>/dev/null | grep -qxF "$ssid"; then
    nmcli connection up id "$ssid"                       # known network
elif printf '%s' "$sel" | grep -q '%)$'; then
    nmcli device wifi connect "$ssid"                    # open (no trailing *)
else
    pw=$(printf '' | fuzzel --dmenu --password --prompt="Password for $ssid > ") || exit 0
    [ -n "$pw" ] && nmcli device wifi connect "$ssid" password "$pw"
fi
